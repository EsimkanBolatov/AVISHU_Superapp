generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  franchisee
  production
}

enum ProductAvailability {
  in_stock
  preorder
}

enum OrderStatus {
  pending_franchisee
  in_production
  ready
}

model User {
  id              String   @id
  name            String
  role            Role     @unique
  loyaltyProgress Int      @default(0)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Product {
  id           String              @id
  sku          String              @unique
  name         String
  price        String
  availability ProductAvailability
  style        String[]
  description  String
  orders       Order[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Order {
  id            String      @id
  number        String      @unique
  productId     String
  customerId    String
  status        OrderStatus
  notes         String
  scheduledDate DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  product  Product @relation(fields: [productId], references: [id])
  customer User    @relation(fields: [customerId], references: [id])
}
