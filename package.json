{
  "name": "avishu_superapp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "concurrently -n FRONT,CORE -c white,gray \"npm run dev:web\" \"npm run dev:core\"",
    "dev:core": "npm --prefix server/core-api run dev",
    "dev:web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/oswald": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~55.0.6",
    "concurrently": "^9.2.1",
    "expo": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-localization": "~55.0.9",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "i18next": "^25.10.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
