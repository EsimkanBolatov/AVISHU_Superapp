{
  "name": "avishu_superapp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "concurrently -n FRONT,CORE -c white,gray \"npm run dev:web\" \"npm run dev:core\"",
    "dev:core": "npm --prefix server/core-api run dev",
    "dev:web": "expo start --web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "npm --prefix server/core-api run db:migrate",
    "db:seed": "npm --prefix server/core-api run db:seed",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/oswald": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "concurrently": "^9.2.1",
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "i18next": "^25.10.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.6.6",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
